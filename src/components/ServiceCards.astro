<style>
  .services {
    padding: 0 80px 140px;
  }
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .service-card-outer {
    position: relative;
    border-radius: 12px;
    padding: 1px;
    background: linear-gradient(160deg, rgba(88,88,88,0.3) 0%, rgba(88,88,88,0.08) 50%, rgba(88,88,88,0.3) 100%);
    background-size: 200% 200%;
    opacity: 0;
    transform: translateY(50px);
    transition: background 0.6s, box-shadow 0.6s;
  }
  .service-card-outer:hover {
    background: linear-gradient(160deg, rgba(212,90,42,0.5) 0%, rgba(248,137,94,0.1) 40%, rgba(212,90,42,0.4) 100%);
    box-shadow:
      0 0 40px rgba(212, 90, 42, 0.06),
      0 8px 32px rgba(0, 0, 0, 0.4);
    animation: shimmerBorder 3s linear infinite;
  }
  @keyframes shimmerBorder {
    0% { background-position: 0% 0%; }
    100% { background-position: 200% 200%; }
  }

  .service-card {
    position: relative;
    border-radius: 11px;
    padding: 100px 28px 48px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 28px;
    background: linear-gradient(180deg, rgba(15,15,15,0.95) 0%, rgba(5,5,5,0.98) 100%);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    transition: background 0.5s;
  }

  .service-card::before {
    content: '';
    position: absolute; inset: 0;
    border-radius: 11px;
    background: radial-gradient(ellipse at 50% -20%, rgba(212, 90, 42, 0.08) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.6s;
  }
  .service-card-outer:hover .service-card::before { opacity: 1; }

  .service-card::after {
    content: '';
    position: absolute;
    top: 0; left: -100%;
    width: 60%; height: 1px;
    background: linear-gradient(90deg, transparent, rgba(248,137,94,0.3), transparent);
    transition: left 0.8s ease;
    pointer-events: none;
  }
  .service-card-outer:hover .service-card::after {
    left: 140%;
  }

  .service-number {
    position: absolute;
    top: 24px; right: 24px;
    font-family: var(--font-mono);
    font-size: 22px;
    background: linear-gradient(to bottom, var(--accent-from), var(--accent-to));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .service-icon {
    width: 180px; height: 140px;
    opacity: 0.15;
    transition: opacity 0.5s, transform 0.5s;
  }
  .service-icon svg { width: 100%; height: 100%; }
  .service-card-outer:hover .service-icon {
    opacity: 0.3;
    transform: scale(1.05);
  }
  .service-card-outer:hover .iso-cube { animation: cubeFloat 3s ease-in-out infinite; }
  @keyframes cubeFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  .service-title {
    font-family: var(--font-display);
    font-weight: 100;
    font-size: clamp(28px, 3vw, 42px);
    color: var(--light1);
    line-height: 1.2;
  }

  .service-detail {
    font-family: var(--font-display);
    font-weight: 100;
    font-size: clamp(20px, 2vw, 26px);
    color: var(--light3);
    cursor: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    width: fit-content;
    position: relative;
    transition: color 0.4s;
  }
  .service-detail::after {
    content: '→';
    opacity: 0;
    transform: translateX(-8px);
    transition: opacity 0.4s, transform 0.4s;
  }
  .service-card-outer:hover .service-detail { color: var(--light1); }
  .service-card-outer:hover .service-detail::after {
    opacity: 1;
    transform: translateX(0);
  }
</style>
